generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
}

model User {
  id        String   @id @default(uuid())
  auth0Id   String   @unique @map("auth0_id")
  email     String   @unique
  name      String?
  role      Role     @default(USER)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  fitbitToken      FitbitToken?
  profile          UserProfile?
  workoutTemplates WorkoutTemplate[]
  workoutLogs      WorkoutLog[]
  customFoods      CustomFood[]
  foodLogs         FoodLog[]

  @@map("users")
}

model FitbitToken {
  id           String   @id @default(uuid())
  userId       String   @unique @map("user_id")
  fitbitUserId String   @map("fitbit_user_id")
  accessToken  String   @map("access_token")
  refreshToken String   @map("refresh_token")
  expiresAt    DateTime @map("expires_at")
  scope        String
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("fitbit_tokens")
}

model UserProfile {
  id                 String   @id @default(uuid())
  userId             String   @unique @map("user_id")
  goal               String
  age                Int
  heightFeet         Int      @map("height_feet")
  heightInches       Int      @map("height_inches")
  weightLbs          Float    @map("weight_lbs")
  gender             String
  activityLevel      Float    @map("activity_level")
  targetWeightLbs    Float    @map("target_weight_lbs")
  weeklyRateLbs      Float    @map("weekly_rate_lbs")
  bmr                Float
  tdee               Float
  dailyCalorieTarget Int      @map("daily_calorie_target")
  proteinPct         Int      @map("protein_pct")
  carbPct            Int      @map("carb_pct")
  fatPct             Int      @map("fat_pct")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

model WorkoutTemplate {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  name        String
  description String
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user      User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  exercises WorkoutTemplateExercise[]

  @@map("workout_templates")
}

model WorkoutTemplateExercise {
  id         String @id @default(uuid())
  templateId String @map("template_id")
  name       String
  weightLbs  Float  @map("weight_lbs")
  sets       Int
  reps       Int
  position   Int

  template WorkoutTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@map("workout_template_exercises")
}

model WorkoutLog {
  id                 String   @id @default(uuid())
  userId             String   @map("user_id")
  templateId         String?  @map("template_id")
  date               String
  description        String?
  fitbitWorkoutName  String?  @map("fitbit_workout_name")
  notes              String?
  createdAt          DateTime @default(now()) @map("created_at")

  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  exercises WorkoutLogExercise[]

  @@unique([userId, date, fitbitWorkoutName])
  @@map("workout_logs")
}

model WorkoutLogExercise {
  id        String @id @default(uuid())
  logId     String @map("log_id")
  name      String
  weightLbs Float  @map("weight_lbs")
  sets      Int
  reps      Int
  position  Int

  log WorkoutLog @relation(fields: [logId], references: [id], onDelete: Cascade)

  @@map("workout_log_exercises")
}

model CustomFood {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  name        String
  brand       String?
  servingSize Float    @map("serving_size")
  servingUnit String   @map("serving_unit")
  calories    Float
  proteinG    Float    @map("protein_g")
  carbsG      Float    @map("carbs_g")
  fatG        Float    @map("fat_g")
  photoUrl    String?  @map("photo_url")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  foodLogs FoodLog[]

  @@map("custom_foods")
}

model FoodLog {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  date         String
  mealCategory String   @map("meal_category")
  foodName     String   @map("food_name")
  fdcId        String?  @map("fdc_id")
  customFoodId String?  @map("custom_food_id")
  servingQty   Float    @map("serving_qty")
  servingSize  Float    @map("serving_size")
  servingUnit  String   @map("serving_unit")
  calories     Float
  proteinG     Float    @map("protein_g")
  carbsG       Float    @map("carbs_g")
  fatG         Float    @map("fat_g")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  customFood CustomFood? @relation(fields: [customFoodId], references: [id], onDelete: SetNull)

  @@map("food_logs")
}
