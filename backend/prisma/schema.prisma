generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
}

model User {
  id        String   @id @default(uuid())
  auth0Id   String   @unique @map("auth0_id")
  email     String   @unique
  name      String?
  role      Role     @default(USER)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  fitbitToken FitbitToken?
  profile     UserProfile?

  @@map("users")
}

model FitbitToken {
  id           String   @id @default(uuid())
  userId       String   @unique @map("user_id")
  fitbitUserId String   @map("fitbit_user_id")
  accessToken  String   @map("access_token")
  refreshToken String   @map("refresh_token")
  expiresAt    DateTime @map("expires_at")
  scope        String
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("fitbit_tokens")
}

model UserProfile {
  id                 String   @id @default(uuid())
  userId             String   @unique @map("user_id")
  goal               String
  age                Int
  heightFeet         Int      @map("height_feet")
  heightInches       Int      @map("height_inches")
  weightLbs          Float    @map("weight_lbs")
  gender             String
  activityLevel      Float    @map("activity_level")
  targetWeightLbs    Float    @map("target_weight_lbs")
  weeklyRateLbs      Float    @map("weekly_rate_lbs")
  bmr                Float
  tdee               Float
  dailyCalorieTarget Int      @map("daily_calorie_target")
  proteinPct         Int      @map("protein_pct")
  carbPct            Int      @map("carb_pct")
  fatPct             Int      @map("fat_pct")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}
